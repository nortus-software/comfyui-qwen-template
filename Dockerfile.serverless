# Serverless image — everything baked in for minimal cold start
FROM nvidia/cuda:12.8.1-cudnn-devel-ubuntu24.04 AS base

ENV DEBIAN_FRONTEND=noninteractive \
    PIP_PREFER_BINARY=1 \
    PYTHONUNBUFFERED=1 \
    CMAKE_BUILD_PARALLEL_LEVEL=8

RUN --mount=type=cache,target=/var/cache/apt,sharing=locked \
    apt-get update && \
    apt-get install -y --no-install-recommends \
        software-properties-common && \
    add-apt-repository ppa:deadsnakes/ppa && \
    apt-get update && \
    apt-get install -y --no-install-recommends \
        python3.11 python3.11-venv python3.11-dev \
        python3-pip \
        curl ffmpeg ninja-build git aria2 git-lfs wget \
        libgl1 libglib2.0-0 build-essential gcc && \
    ln -sf /usr/bin/python3.11 /usr/bin/python && \
    ln -sf /usr/bin/python3.11 /usr/bin/python3 && \
    ln -sf /usr/bin/pip3 /usr/bin/pip && \
    python3.11 -m venv /opt/venv && \
    apt-get clean && rm -rf /var/lib/apt/lists/*

ENV PATH="/opt/venv/bin:$PATH"

# PyTorch
RUN --mount=type=cache,target=/root/.cache/pip \
    pip install torch torchvision torchaudio \
        --index-url https://download.pytorch.org/whl/cu128

# Core tooling
RUN --mount=type=cache,target=/root/.cache/pip \
    pip install packaging setuptools wheel

# Runtime libraries
RUN --mount=type=cache,target=/root/.cache/pip \
    pip install pyyaml gdown triton comfy-cli

# ComfyUI
RUN --mount=type=cache,target=/root/.cache/pip \
    /usr/bin/yes | comfy --workspace /ComfyUI install

# Pre-install qwen-vl-utils and opencv
RUN --mount=type=cache,target=/root/.cache/pip \
    pip install "qwen-vl-utils>=0.0.8" opencv-python

# ComfyUI's own dependencies
RUN --mount=type=cache,target=/root/.cache/pip \
    pip install -r /ComfyUI/requirements.txt

# Handler dependencies
RUN --mount=type=cache,target=/root/.cache/pip \
    pip install runpod google-cloud-storage requests sqlalchemy

# ── SageAttention — cached separately so rebuilds skip this ──
FROM base AS sage
RUN --mount=type=cache,target=/root/.cache/pip \
    export EXT_PARALLEL=1 MAX_JOBS=2 && \
    cd /tmp && \
    git clone https://github.com/thu-ml/SageAttention.git && \
    cd SageAttention && \
    git reset --hard 68de379 && \
    sed -i 's/^compute_capabilities = set()$/compute_capabilities = {"12.0"}/' setup.py && \
    sed -i '/^device_count/d; /^for i in range/,/compute_capabilities.add/d' setup.py && \
    sed -i 's/if not compute_capabilities:/if False:/' setup.py && \
    pip install . && \
    rm -rf /tmp/SageAttention

# ── Models — cached separately so rebuilds skip downloads ──
FROM base AS models
RUN mkdir -p /models/diffusion_models /models/text_encoders /models/vae /models/hf_cache

RUN aria2c -x 16 -s 16 -k 1M \
    -d /models/diffusion_models -o z_image_turbo_bf16.safetensors \
    "https://huggingface.co/Comfy-Org/z_image_turbo/resolve/main/split_files/diffusion_models/z_image_turbo_bf16.safetensors"

RUN aria2c -x 16 -s 16 -k 1M \
    -d /models/text_encoders -o qwen_3_4b.safetensors \
    "https://huggingface.co/Comfy-Org/z_image_turbo/resolve/main/split_files/text_encoders/qwen_3_4b.safetensors"

RUN aria2c -x 16 -s 16 -k 1M \
    -d /models/vae -o ae.safetensors \
    "https://huggingface.co/modelzpalace/ae.safetensors/resolve/main/ae.safetensors"

# Pre-download Qwen2.5-VL-7B-Instruct into HF cache (used by HearmemanAI nodes)
ENV HF_HOME=/models/hf_cache
RUN pip install --no-cache-dir huggingface_hub && \
    python -c "from huggingface_hub import snapshot_download; snapshot_download('Qwen/Qwen2.5-VL-7B-Instruct')"

# ── Custom nodes — cached separately ──
FROM base AS custom-nodes
RUN --mount=type=cache,target=/root/.cache/pip \
    for repo in \
    https://github.com/kijai/ComfyUI-KJNodes.git \
    https://github.com/rgthree/rgthree-comfy.git \
    https://github.com/JPS-GER/ComfyUI_JPS-Nodes.git \
    https://github.com/ClownsharkBatwing/RES4LYF.git \
    https://github.com/cubiq/ComfyUI_essentials.git \
    https://github.com/chflame163/ComfyUI_LayerStyle_Advance.git \
    https://github.com/M1kep/ComfyLiterals.git \
    https://github.com/Hearmeman24/ComfyUI-Realistic-Nodes.git; \
    do \
        cd /ComfyUI/custom_nodes; \
        repo_dir=$(basename "$repo" .git); \
        git clone --depth 1 "$repo"; \
        if [ -f "/ComfyUI/custom_nodes/$repo_dir/requirements.txt" ]; then \
            pip install -r "/ComfyUI/custom_nodes/$repo_dir/requirements.txt"; \
        fi; \
        if [ -f "/ComfyUI/custom_nodes/$repo_dir/install.py" ]; then \
            python "/ComfyUI/custom_nodes/$repo_dir/install.py"; \
        fi; \
    done

# ── Final image ──
FROM base AS final

# Copy SageAttention from cached stage
COPY --from=sage /opt/venv /opt/venv

# Copy custom nodes and their pip deps from cached stage
COPY --from=custom-nodes /ComfyUI/custom_nodes/ /ComfyUI/custom_nodes/
COPY --from=custom-nodes /opt/venv /opt/venv

# Copy models from cached stage
COPY --from=models /models/diffusion_models/ /ComfyUI/models/diffusion_models/
COPY --from=models /models/text_encoders/ /ComfyUI/models/text_encoders/
COPY --from=models /models/vae/ /ComfyUI/models/vae/
COPY --from=models /models/hf_cache/ /root/.cache/huggingface/
RUN mkdir -p /ComfyUI/models/loras /ComfyUI/models/upscale_models
ENV HF_HOME=/root/.cache/huggingface \
    HF_HUB_OFFLINE=1 \
    TRANSFORMERS_OFFLINE=1

# Private custom nodes via BuildKit secrets
RUN --mount=type=secret,id=GITHUB_PAT \
    cd /ComfyUI/custom_nodes && \
    git clone --depth 1 "https://$(cat /run/secrets/GITHUB_PAT)@github.com/nortus-software/ComfyUI-HMNodes.git" && \
    if [ -f "ComfyUI-HMNodes/requirements.txt" ]; then pip install -r ComfyUI-HMNodes/requirements.txt; fi

RUN --mount=type=secret,id=GITHUB_PAT \
    cd /ComfyUI/custom_nodes && \
    git clone --depth 1 "https://$(cat /run/secrets/GITHUB_PAT)@github.com/nortus-software/airobust_custom_nodes.git" && \
    if [ -f "airobust_custom_nodes/requirements.txt" ]; then pip install -r airobust_custom_nodes/requirements.txt; fi

# Workflow JSON — baked in from private repo
# Bump WORKFLOW_VERSION to force re-clone of workflow repo
ARG WORKFLOW_VERSION=1
RUN --mount=type=secret,id=GITHUB_PAT \
    echo "workflow version: ${WORKFLOW_VERSION}" && \
    git clone --depth 1 "https://$(cat /run/secrets/GITHUB_PAT)@github.com/nortus-software/z_image_first_frame_match.git" /tmp/workflows && \
    mkdir -p /ComfyUI/user/default/workflows && \
    cp /tmp/workflows/*.json /ComfyUI/user/default/workflows/ && \
    ls -la /ComfyUI/user/default/workflows/ && \
    rm -rf /tmp/workflows

# Copy handler code
COPY src/handler.py src/comfyui_client.py src/gcs.py src/config.py \
     src/source_downloader.py src/workflow_injector.py src/lora_cache.py /app/
COPY src/__init__.py /app/__init__.py

# Copy startup script
COPY src/start_serverless.sh /start_serverless.sh
RUN chmod +x /start_serverless.sh

CMD ["/start_serverless.sh"]
